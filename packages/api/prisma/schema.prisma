generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id
  title       String
  imageUrl    String
  description String?
  start       DateTime
  fetchedAt   DateTime @default(now())
}

model AccessRanking {
  id        String   @id
  title     String
  imageUrl  String
  rank      Int
  start     DateTime
  fetchedAt DateTime @default(now())
}
