FEED_URL=
FEED_IMAGE_BASE_URL=
FEED_FETCH_INTERVAL_MIN=30
# 気象庁 防災情報XML（天気予報スライド用。API キー不要）
# 既定値は静岡県（府県 220000 / 区域 東部 220030 / 気温地点 三島 50206）= 沼津向け
WEATHER_JMA_FEED_URL=https://www.data.jma.go.jp/developer/xml/feed/regular_l.xml
WEATHER_JMA_PREF_CODE=220000
WEATHER_JMA_AREA_CODE=220030
WEATHER_JMA_TEMP_POINT=50206
WEATHER_FETCH_INTERVAL_MIN=30
VITE_SLIDE_DURATION_SEC=8

# admin 認証 (Auth0 / OIDC)。未設定の間は admin の認証を fail-open でスキップする。
# Auth0 では「Regular Web Application」を作成し、Allowed Callback URLs に
# OIDC_REDIRECT_URI を、Allowed Logout URLs に admin トップ URL を登録すること。
OIDC_ISSUER=                                   # 例: https://<tenant>.auth0.com (末尾スラッシュ無し)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_SECRET=                              # セッション JWT 署名鍵。32 文字以上のランダム文字列
OIDC_REDIRECT_URI=http://localhost:5174/api/auth/callback
OIDC_SCOPES=openid profile email
OIDC_AUDIENCE=                                 # 任意 (api 向けアクセストークンが必要な場合のみ)
OIDC_AUTH_EXTERNAL_URL=http://localhost:5174   # dev の http で Secure Cookie を無効化するために必要
ADMIN_BASE_URL=/                               # ログイン/ログアウト後の戻り先 (prod は /admin/)
